# Dedicated Telegram bot token for codex-ops.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs.
ALLOWED_CHAT_IDS=

# Runtime paths.
INCIDENTS_DIR=/srv/codex-ops/incidents
STATE_DIR=/var/lib/codexops/state
OPENCLAW_CONTAINER=openclaw-yvrh-openclaw-1
CODEX_CWD=/srv/codex-ops/incidents
HOST_LABEL=
GLOBAL_CHANGELOG_FILE=/srv/codex-ops/CHANGELOG.md

# Prompt language sent to Codex (example: Russian, English).
ASSISTANT_LANGUAGE=Russian

# Optional context tuning.
HISTORY_ITEMS=8
HISTORY_ITEM_CHARS=1400
HISTORICAL_INCIDENT_LIMIT=4000

# Optional Telegram output tuning.
TELEGRAM_FORMAT=html
MAX_MESSAGE=3500
MAX_MESSAGE_CHUNKS=4
OUTBOUND_DELAY_MS=250
TG_RETRY_ATTEMPTS=3
TG_RETRY_FALLBACK_DELAY_MS=2000
TG_RETRY_MAX_WAIT_MS=120000

# Device auth timeout in milliseconds.
CODEX_DEVICE_AUTH_TIMEOUT_MS=900000

# Codex exec timeout in milliseconds.
# Set 0 to disable timeout and wait until real completion.
CODEX_EXEC_TIMEOUT_MS=0

# Progress updates while codex exec is still running.
# Set 0 to disable. Positive values below 60000 are raised to 60000.
CODEX_PROGRESS_INTERVAL_MS=300000
CODEX_PROGRESS_MAX_CHARS=1800
