# Dedicated Telegram bot token for codex-ops.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs.
# Multiple IDs enable multi-chat mode for trusted operators.
ALLOWED_CHAT_IDS=

# Runtime paths.
INCIDENTS_DIR=/srv/codex-ops/incidents
STATE_DIR=/var/lib/codexops/state
UPLOADS_DIR=/var/lib/codexops/state/uploads
OPENCLAW_CONTAINER=openclaw-yvrh-openclaw-1
CODEX_CWD=/srv/codex-ops/incidents
HOST_LABEL=

# Prompt language sent to Codex (example: Russian, English).
ASSISTANT_LANGUAGE=Russian

# Optional context tuning.
HISTORY_ITEMS=8
HISTORY_ITEM_CHARS=1400
HISTORICAL_INCIDENT_LIMIT=4000

# Durable host request queues and reminders.
# Set HOST_REQUEST_POLL_INTERVAL_MS=0 to disable.
HOST_REQUEST_POLL_INTERVAL_MS=3600000
HOST_REQUEST_STARTUP_DELAY_MS=30000
HOST_REQUEST_RUNNING_STALE_MS=21600000
HOST_REQUEST_DIR_NAMES=host-requests,staging-requests,scheduled-requests
HOST_REQUEST_DIRS=

# Optional Telegram image input tuning.
TELEGRAM_IMAGE_MAX_BYTES=10000000
PENDING_IMAGE_TTL_MS=1800000
PENDING_IMAGE_MAX_ITEMS=4

# Optional Telegram voice input via OpenRouter.
# Keep the real key in /etc/codex-ops/bot.env or another server-only env file.
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_FILE=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_STT_MODEL=openai/whisper-1
OPENROUTER_PLAN_MODEL=openai/gpt-4o-mini
OPENROUTER_TRANSCRIPTION_LANGUAGE=
OPENROUTER_TIMEOUT_MS=60000
OPENROUTER_SCAN_PROJECT_ENV=1
TELEGRAM_VOICE_MAX_BYTES=25000000
VOICE_DRAFT_TTL_MS=1800000

# Optional Telegram output tuning.
TELEGRAM_FORMAT=html
MAX_MESSAGE=3500
MAX_MESSAGE_CHUNKS=4
OUTBOUND_DELAY_MS=250
TG_RETRY_ATTEMPTS=3
TG_RETRY_FALLBACK_DELAY_MS=2000
TG_RETRY_MAX_WAIT_MS=120000
TELEGRAM_POLL_ERROR_LOG_INTERVAL_MS=60000

# Device auth timeout in milliseconds.
CODEX_DEVICE_AUTH_TIMEOUT_MS=900000

# Codex exec timeout in milliseconds.
# Set 0 to disable timeout and wait until real completion.
CODEX_EXEC_TIMEOUT_MS=0
CODEX_MODEL_CATALOG_TIMEOUT_MS=30000

# Progress updates while codex exec is still running.
# Set 0 to disable. Positive values below 60000 are raised to 60000.
CODEX_PROGRESS_INTERVAL_MS=300000
CODEX_PROGRESS_MAX_CHARS=1800
